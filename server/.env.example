# ===================== Razorpay (payments) =====================
# From Razorpay Dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-NEVER-in-frontend
# Optional: only if you enable webhooks in the Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ===================== Bigship (shipping) =====================
BIGSHIP_BASE_URL=https://api.bigship.in/
BIGSHIP_USER_NAME=your-bigship-login-email
BIGSHIP_PASSWORD=your-bigship-password
BIGSHIP_ACCESS_KEY=your-access-key
# Run GET /api/shipping/warehouses once to find your warehouse_id
BIGSHIP_PICKUP_LOCATION_ID=44156
BIGSHIP_RETURN_LOCATION_ID=44156

# ===================== Server =====================
PORT=4000
ALLOWED_ORIGINS=http://localhost:5173,https://www.bashabos.com
